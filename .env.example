# GitEmpire — Environment Variables

# ── Required for live GitHub Actions mode ─────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here      # get free key at https://console.groq.com
GITHUB_TOKEN=your_github_token_here       # auto-injected by GitHub Actions — only needed locally

# ── ClawLess browser runtime (optional overrides) ─────────────────────────────
# CLAWLESS_MODEL=claude-sonnet-4-20250514 # override gitclaw model in ClawLess browser runtime
#                                          # defaults to groq:llama-3.3-70b-versatile from agent.yaml
#                                          # use Anthropic/OpenAI/Google IDs if GROQ is unavailable in browser
